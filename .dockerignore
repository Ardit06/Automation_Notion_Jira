# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (should be passed at runtime)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Git
.git
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.classpath

# OS files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Logs (but keep src/config)
*.log
logs/
!src/config/

# Test files
test/
tests/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
.cache/

# Build artifacts (already built in container)
dist/

# Railway files
railway.toml
Procfile

# Other CI/CD files
.github/
.gitlab-ci.yml
.circleci/
.travis.yml

# Documentation (not needed in runtime)
docs/
*.md
!README.md

# Config files not needed
.editorconfig
.prettierrc
.eslintrc*
.babelrc
tsconfig.json

# Package manager locks (use package-lock.json in image)
yarn.lock
pnpm-lock.yaml

# Docker files (don't nest them)
Dockerfile
docker-compose*.yml
.dockerignore
