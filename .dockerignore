# Dependencies (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (should be passed at runtime)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup.*

# Git
.git/
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.classpath

# OS files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Logs
*.log
logs/
tunnel.log
localtunnel.log
token-rotation.log

# Test files
test/
tests/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
test-results/

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
.cache/
.parcel-cache
*.tmp
*.temp
*.backup
*.bak

# Build artifacts (already built in container)
dist/

# Railway files
railway.toml
Procfile

# Other CI/CD files
.github/
.gitlab-ci.yml
.circleci/
.travis.yml

# Documentation (not needed in runtime)
docs/
*.md
!README.md

# Config files not needed (keep tsconfig.json for build!)
.editorconfig
.prettierrc
.eslintrc*
.babelrc

# Package manager locks (keep package-lock.json, exclude others)
yarn.lock
pnpm-lock.yaml

# Docker files (don't nest them)
Dockerfile
docker-compose*.yml
.dockerignore

# Security files
*.pem
*.key
*.crt
*.p12
*.pfx

# TypeScript cache
*.tsbuildinfo

# Cache directories
.npm
.eslintcache
