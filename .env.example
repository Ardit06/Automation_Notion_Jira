# Copy to .env and fill in. See CONFIG_GUIDE.md.

# --- Notion (required) ---
NOTION_API_KEY=
NOTION_USER_STORIES_DATABASE_ID=
NOTION_EPICS_DATABASE_ID=
NOTION_WEBHOOK_SECRET=

# --- Jira (required) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# --- Server ---
PORT=3003
NODE_ENV=development

# Optional: Notion user IDs (comma-separated). Empty = allow all.
# AUTHORIZED_USERS=

# Optional notifications
SCRUM_MASTER_EMAILS=
ENABLE_STATUS_CHANGE_COMMENTS=true

# Dev only: accept unsigned webhook POSTs (ignored when NODE_ENV=production)
# ALLOW_UNSIGNED_WEBHOOKS=true

# Optional Jira custom field overrides (only if your instance differs)
# JIRA_STORY_POINTS_FIELD_ID=customfield_10016
# JIRA_FIGMA_LINK_FIELD_ID=customfield_10021
# JIRA_EPIC_TYPE_FIELD_ID=customfield_12224
# JIRA_EPIC_TYPE_VALUE=11209
# JIRA_EPIC_LINK_FIELD_ID=customfield_10011
# JIRA_DEV_START_DATE_FIELD_ID=customfield_10020
# JIRA_DEV_END_DATE_FIELD_ID=customfield_10022
