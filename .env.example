# Copy to .env and fill in values. See CONFIG_GUIDE.md.

NOTION_API_KEY=
NOTION_USER_STORIES_DATABASE_ID=
NOTION_EPICS_DATABASE_ID=
NOTION_WEBHOOK_SECRET=

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

PORT=3003
NODE_ENV=development

# Optional: comma-separated Notion user IDs allowed to trigger automation (empty = no filter)
# AUTHORIZED_USERS=

SCRUM_MASTER_EMAILS=
ENABLE_STATUS_CHANGE_COMMENTS=true

# Local dev only: test webhooks without Notion signing (ignored in production)
# ALLOW_UNSIGNED_WEBHOOKS=true
